APP_HOST=127.0.0.1
APP_PORT=8787
APP_ORIGIN=*
APP_TITLE=Codex Chat
SITE_URL=http://127.0.0.1:8787

INTERNAL_ONLY=true
ALLOW_PUBLIC_SIGNUP=false
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-now
ADMIN_NAME=Admin
SESSION_TTL_SECONDS=2592000

CODEX_BIN=codex
CODEX_EXEC_BIN=
AGENT_PROVIDER_MODE=host
CODEX_WORKSPACE_ROOT=./workspaces
LINUX_USER_POOL_PREFIX=codexweb
LINUX_USER_POOL_START=1
LINUX_USER_POOL_SIZE=100
LINUX_SANDBOX_ROOT=/var/lib/codex-chat/sandboxes
CODEX_RUN_AS_LINUX_USER=false
CODEX_MODEL=
CODEX_WEB_API_KEY=
CODEX_WEB_BASE_URL=
CODEX_ALLOW_DANGEROUS=false

PROOT_BIN=
PROOT_LIB_DIR=

SUB2API_BASE_URL=http://127.0.0.1:8080
SUB2API_ADMIN_EMAIL=
SUB2API_ADMIN_PASSWORD=
SUB2API_MODEL=gpt-5.4
SUB2API_PLUS_CONCURRENCY=5
SUB2API_FREE_CONCURRENCY=0
SUB2API_USER_EMAIL_DOMAIN=sub2api.local
SUB2API_TIMEOUT_SECONDS=20

LLM_WEB_AGENT_BASE_URL=
LLM_WEB_AGENT_TOKEN=
LLM_WEB_AGENT_ENV_FILE=
LLM_WEB_AGENT_MODEL=gpt-5-3
LLM_WEB_AGENT_TIMEOUT_SECONDS=300

STORAGE_DIR=./storage
